<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calcul IMC — Calviro</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">
  <nav class="nav">
    <a href="index.html" class="brand"><span class="brand-dot"></span>Calviro</a>
    <a href="index.html" class="back">← Retour</a>
  </nav>

  <div class="tool">
    <div class="tool-header">
      <h1>⚖️ Indice de masse corporelle</h1>
      <p>Calcul de ton IMC et de la fourchette de poids santé.</p>
    </div>

    <div class="field-row">
      <div class="field">
        <label for="imc-poids">Poids (kg)</label>
        <input type="number" id="imc-poids" placeholder="70" min="0" step="0.1">
      </div>
      <div class="field">
        <label for="imc-taille">Taille (cm)</label>
        <input type="number" id="imc-taille" placeholder="175" min="0">
      </div>
    </div>

    <button class="btn" onclick="calcIMC()">Calculer mon IMC</button>

    <div class="result" id="imc-result"></div>
  </div>
</div>

<script src="script.js"></script>
</body>
</html>
